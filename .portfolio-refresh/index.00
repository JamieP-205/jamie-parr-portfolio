<!doctype html><html lang="en-GB" class="no-js"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>Jamie Parr | Software, Web &amp; Game Projects | Belfast</title><meta name="description" content="Jamie Parr is a Computing Technologies student at Ulster University in Belfast building tested software, adaptive learning platforms, production websites and a playable Godot game."><meta name="author" content="Jamie Parr"><meta name="robots" content="index, follow"><link rel="canonical" href="https://jamie-parr-portfolio.netlify.app/"><meta property="og:title" content="Jamie Parr | Software, Web &amp; Game Projects"><meta property="og:description" content="Belfast-based Computing Technologies student building a playable Godot campaign, adaptive learning platforms and production web systems."><meta property="og:type" content="website"><meta property="og:url" content="https://jamie-parr-portfolio.netlify.app/"><meta property="og:image" content="https://jamie-parr-portfolio.netlify.app/assets/og-card.png"><meta property="og:image:width" content="1200"><meta property="og:image:height" content="630"><meta name="twitter:card" content="summary_large_image"><meta name="theme-color" content="#f7f5f0"><link rel="icon" href="assets/favicon.svg" type="image/svg+xml"><link rel="manifest" href="site.webmanifest"><link rel="stylesheet" href="styles.css"><link rel="stylesheet" href="project-showcase.css"></head><body><a class="skip-link" href="#main">Skip to main content</a><header class="site-header"><div class="container header-inner"><a class="brand" href="index.html" aria-label="Jamie Parr homepage"><span class="brand-mark" aria-hidden="true">JP</span><span class="brand-text">Jamie Parr</span></a><button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav"><span class="sr-only">Toggle navigation</span><span aria-hidden="true"></span><span aria-hidden="true"></span><span aria-hidden="true"></span></button><